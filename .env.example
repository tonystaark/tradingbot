# Alpaca API credentials
# Get from https://app.alpaca.markets/
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Trading mode: 'paper' (default) or 'live'
TRADING_MODE=paper

# Symbols to trade (comma-separated)
SYMBOLS=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,SPY

# Moving average windows
MA_SHORT_WINDOW=20
MA_LONG_WINDOW=50

# Backtest history length in days (1500 ≈ 6 years)
BACKTEST_DAYS=1500

# Risk management
RISK_PER_TRADE=0.02
MAX_POSITIONS=5
DAILY_LOSS_LIMIT=0.05

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Bot API port
BOT_PORT=3001
